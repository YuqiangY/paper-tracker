<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
         max-width: 900px; margin: 0 auto; padding: 20px; color: #333; background: #fafafa; }
  h1 { margin-bottom: 24px; }
  .date-list { list-style: none; }
  .date-list li { margin-bottom: 8px; }
  .date-list a { color: #4a90d9; text-decoration: none; font-size: 1.1em; }
  .date-list a:hover { text-decoration: underline; }
</style>
</head>
<body>
<h1>{{ title }}</h1>
<ul class="date-list">
{% for date in dates %}
  <li><a href="{{ date }}.html">{{ date }}</a></li>
{% endfor %}
</ul>
</body>
</html>
