<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }} - {{ date }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
         color: #333; background: #fafafa; }

  .layout { display: flex; max-width: 1200px; margin: 0 auto; }

  /* Sidebar */
  .sidebar { width: 220px; position: sticky; top: 0; height: 100vh; overflow-y: auto;
             padding: 20px 16px; border-right: 1px solid #e0e0e0; background: #fff; flex-shrink: 0; }
  .sidebar h3 { font-size: 0.85em; color: #666; text-transform: uppercase; letter-spacing: 0.5px;
                margin-bottom: 12px; }
  .sidebar-nav { list-style: none; }
  .sidebar-nav li { margin-bottom: 4px; }
  .sidebar-nav a { display: block; padding: 6px 10px; border-radius: 6px; color: #333;
                   text-decoration: none; font-size: 0.9em; transition: background 0.15s; }
  .sidebar-nav a:hover { background: #e8f0fe; }
  .sidebar-nav a.active { background: #4a90d9; color: #fff; }
  .sidebar-nav .nav-count { float: right; color: #999; font-size: 0.8em; }
  .sidebar-nav a.active .nav-count { color: rgba(255,255,255,0.8); }
  .sidebar-back { display: block; margin-bottom: 20px; color: #4a90d9; text-decoration: none;
                  font-size: 0.9em; }
  .sidebar-meta { font-size: 0.8em; color: #999; margin-top: 16px; padding-top: 12px;
                  border-top: 1px solid #eee; }

  /* Main content */
  .main { flex: 1; min-width: 0; padding: 24px 32px; }

  h1 { margin-bottom: 8px; font-size: 1.6em; }
  .meta { color: #666; margin-bottom: 24px; }

  /* Summary section */
  .summary-section { background: #fff; border: 1px solid #e0e0e0; border-radius: 12px;
                     padding: 20px 24px; margin-bottom: 28px;
                     border-left: 4px solid #667eea; }
  .summary-section h2 { font-size: 1em; color: #667eea; margin-bottom: 12px;
                         font-weight: 600; letter-spacing: 0.5px; }
  .summary-section p { margin: 0; line-height: 1.8; color: #444; font-size: 0.92em; }
  .summary-section strong { color: #2c3e50; }

  /* Category sections */
  .category { margin-bottom: 32px; }
  .category h2 { border-bottom: 2px solid #4a90d9; padding-bottom: 6px; margin-bottom: 16px;
                 color: #2c3e50; font-size: 1.2em; }
  .paper { background: #fff; border: 1px solid #e0e0e0; border-radius: 8px; padding: 16px;
           margin-bottom: 12px; }
  .paper-title { font-size: 1.05em; font-weight: 600; }
  .paper-title a { color: #1a0dab; text-decoration: none; }
  .paper-title a:hover { text-decoration: underline; }
  .score { display: inline-block; background: #4a90d9; color: #fff; border-radius: 4px;
           padding: 2px 8px; font-size: 0.85em; margin-left: 8px; }
  .paper .summary { margin: 8px 0; color: #444; line-height: 1.6; }
  .tags { margin-top: 6px; }
  .tag { display: inline-block; background: #e8f0fe; color: #1967d2; border-radius: 3px;
         padding: 2px 8px; font-size: 0.8em; margin-right: 4px; margin-bottom: 4px; }
  .authors { font-size: 0.85em; color: #888; margin-top: 4px; }
  .author-affil { color: #666; font-style: italic; }
  .h-index { display: inline-block; background: #e8f5e9; color: #2e7d32; border-radius: 3px;
             padding: 1px 6px; font-size: 0.75em; margin-left: 2px; font-weight: 600; }
  .h-badge { display: inline-block; background: #fff3e0; color: #e65100; border-radius: 4px;
             padding: 2px 6px; font-size: 0.8em; margin-left: 8px; }

  /* Responsive */
  @media (max-width: 768px) {
    .layout { flex-direction: column; }
    .sidebar { width: 100%; height: auto; position: static; border-right: none;
               border-bottom: 1px solid #e0e0e0; padding: 12px 16px; }
    .sidebar-nav { display: flex; flex-wrap: wrap; gap: 4px; }
    .sidebar-nav li { margin-bottom: 0; }
    .main { padding: 16px; }
  }
</style>
</head>
<body>
<div class="layout">

<!-- Sidebar -->
<aside class="sidebar">
  <a href="index.html" class="sidebar-back">&larr; 返回索引</a>
  <h3>分类导航</h3>
  <ul class="sidebar-nav">
    {% if summary %}
    <li><a href="#summary">今日热点</a></li>
    {% endif %}
    {% for cat_name, cat_papers in categories.items() %}
    <li><a href="#cat-{{ loop.index }}" data-cat="{{ loop.index }}">{{ cat_name }} <span class="nav-count">{{ cat_papers | length }}</span></a></li>
    {% endfor %}
  </ul>
  <div class="sidebar-meta">
    {{ date }}<br>共 {{ papers | length }} 篇
  </div>
</aside>

<!-- Main Content -->
<main class="main">
  <h1>{{ title }}</h1>
  <p class="meta">{{ date }} &middot; {{ papers | length }} papers</p>

  {% if summary %}
  <section class="summary-section" id="summary">
    <h2>今日热点总结</h2>
    {{ summary | safe }}
  </section>
  {% endif %}

  {% for cat_name, cat_papers in categories.items() %}
  <div class="category" id="cat-{{ loop.index }}">
    <h2>{{ cat_name }} ({{ cat_papers | length }})</h2>
    {% for p in cat_papers %}
    <div class="paper">
      <div class="paper-title">
        <a href="{{ p.url }}" target="_blank">{{ p.title }}</a>
        <span class="score">{{ "%.1f" | format(p.relevance_score) if p.relevance_score is not none else "-" }}</span>
      </div>
      <div class="summary">{{ p.summary_zh }}</div>
      <div class="tags">
        {% for tag in p.tags_list %}
        <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>
      <div class="authors">
        {% if p.authors_enriched_list %}
          {% for a in p.authors_enriched_list %}{{ a.name }}{% if a.affiliation %} <span class="author-affil">({{ a.affiliation }})</span>{% endif %}{% if a.h_index is not none %} <span class="h-index">h={{ a.h_index }}</span>{% endif %}{% if not loop.last %}, {% endif %}{% endfor %}
          {% if p.max_h_index is not none %}<span class="h-badge">max h={{ p.max_h_index }}</span>{% endif %}
        {% else %}
          {{ p.authors_list | join(", ") }}
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endfor %}
</main>
</div>

<script>
(function() {
  var sections = document.querySelectorAll('.category, .summary-section');
  var links = document.querySelectorAll('.sidebar-nav a');
  if (!sections.length || !links.length) return;

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        links.forEach(function(l) { l.classList.remove('active'); });
        var id = entry.target.id;
        var active = document.querySelector('.sidebar-nav a[href="#' + id + '"]');
        if (active) active.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -60% 0px' });

  sections.forEach(function(s) { observer.observe(s); });
})();
</script>
</body>
</html>
